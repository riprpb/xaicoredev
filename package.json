{
  "name": "xaicore-platform",
  "version": "1.0.0",
  "description": "XAICore Platform - AI-powered enterprise platform with React, Node.js, TypeScript, and database integration",
  "author": {
    "name": "Ryan Patrick Burbage",
    "email": "riprpb@xaicore.dev",
    "company": "X Ai Core Dev LLC"
  },
  "license": "PROPRIETARY",
  "repository": {
    "type": "git",
    "url": "https://github.com/XAICoreDev/xaicore-platform.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"npm run server:watch\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src vite.config.ts --ext .ts,.tsx",
    "lint:fix": "eslint src vite.config.ts --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "test:database": "vitest run src/database/database.integration.test.ts",
    "test": "vitest run",
    "test:coverage:config": "vitest run src/config --coverage",
    "test:coverage:identity": "vitest run src/identity --coverage --coverage.include=src/identity/*.ts --coverage.exclude=src/identity/*.test.ts --coverage.reportsDirectory=coverage/identity",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "server": "tsx src/server.ts",
    "server:watch": "tsx watch src/server.ts",
    "owner:bootstrap": "tsx src/cli/owner-bootstrap.ts",
    "owner:credentials": "tsx src/cli/owner-credential.ts",
    "owner:mfa": "tsx src/cli/owner-mfa.ts",
    "owner:recovery": "tsx src/cli/owner-recovery.ts",
    "keepassxc:init": "tsx src/cli/keepassxc-init.ts",
    "clean": "rimraf dist node_modules"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pg": "^8.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^15.0.7",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "rimraf": "^5.0.10",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0"
  }
}
