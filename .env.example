# XAICore Gate 1 development configuration

# Runtime profile: development, test, staging, or production
NODE_ENV=development

# Public server configuration
API_HOST=127.0.0.1
API_PORT=3000
API_RATE_LIMIT=100
API_RATE_WINDOW_MS=900000
CORS_ALLOWED_ORIGINS=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Local development secret. Prisma reads this directly; application configuration
# never returns it. Replace the placeholder only in ignored local environment files.
DATABASE_URL=postgresql://xaicore:change-me@localhost:5432/xaicore_dev

# Opaque secret reference for future staging/production resolution. The production
# provider remains unselected pending deployment-target approval.
DATABASE_URL_SECRET_REF=
