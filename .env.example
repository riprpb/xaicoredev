# XAICore Development Environment Variables

# Database
DATABASE_URL=postgresql://xaicore:change-me@localhost:5432/xaicore_dev

# API Keys - OpenAI
OPENAI_API_KEY=sk_test_xxxxxxxxxxxxx

# API Keys - Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxxxxxxxxxxxx

# API Keys - Coinbase
COINBASE_API_KEY=xxxxxxxxxxxxx

# Authentication
JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_EXPIRY=7d

# OAuth (if needed)
GITHUB_CLIENT_ID=xxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxx

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost
API_RATE_LIMIT=100
API_RATE_WINDOW_MS=900000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend Configuration
VITE_API_URL=http://localhost:3000

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# AWS (if using S3 for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
AWS_BUCKET_NAME=xaicore-dev

# Blockchain / Web3
BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/xxxxxxxxxxxxx
PRIVATE_KEY=xxxxxxxxxxxxx

# Feature Flags
ENABLE_HALEY_BRAIN=false
ENABLE_HOPE_SERVICES=false
ENABLE_SCARLETT_X=false
ENABLE_MINING=false
ENABLE_TRADING=false
FEATURE_FLAGS_JSON={"kernel":true,"haley":false,"scarlett":false,"production":false,"billing":false}

# Analytics (if using)
ANALYTICS_ID=xxxxxxxxxxxxx

# Support / Help
SUPPORT_EMAIL=support@xaicore.dev
