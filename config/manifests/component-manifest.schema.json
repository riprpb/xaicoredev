{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xaicore.dev/schemas/component-manifest-1.0.json",
  "title": "XAICore Component Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "displayName",
    "version",
    "kind",
    "description",
    "owner",
    "status",
    "capabilities",
    "permissions",
    "dependencies",
    "endpoints",
    "configurationKeys",
    "documentation"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$"
    },
    "displayName": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "kind": {
      "enum": ["ai", "service", "module", "plugin", "infrastructure"]
    },
    "description": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["experimental", "active", "deprecated", "retired"]
    },
    "capabilities": { "type": "array", "items": { "type": "string" } },
    "permissions": { "type": "array", "items": { "type": "string" } },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "requirement", "versionRange"],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "enum": ["ai", "service", "module", "plugin", "infrastructure"]
          },
          "requirement": { "enum": ["required", "optional"] },
          "versionRange": { "type": "string", "minLength": 1 },
          "capabilities": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "endpoints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["health", "readiness", "liveness"],
      "properties": {
        "health": { "type": "string", "pattern": "^/" },
        "readiness": { "type": "string", "pattern": "^/" },
        "liveness": { "type": "string", "pattern": "^/" },
        "metrics": { "type": "string", "pattern": "^/" }
      }
    },
    "configurationKeys": {
      "type": "array",
      "items": { "type": "string" }
    },
    "featureFlag": { "type": "string" },
    "documentation": { "type": "string", "minLength": 1 }
  }
}
